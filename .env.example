# ─────────────────────────────────────────────────────────────────────────────
# NEXUS Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=nexus_db
POSTGRES_USER=nexus_user
POSTGRES_PASSWORD=nexus_secure_password_change_me
DB_HOST=db
DB_PORT=5432

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-very-long-secret-key-change-in-production-min-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=nexus_core.settings.development

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ALGORITHM=HS256
JWT_SIGNING_KEY=your-jwt-signing-key-change-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TIMEZONE=UTC

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=NEXUS Platform <noreply@nexus.io>

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost/api
VITE_WS_URL=ws://localhost/ws
VITE_APP_NAME=NEXUS

# ── Registry (production) ─────────────────────────────────────────────────────
REGISTRY=ghcr.io/your-org
TAG=latest

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_REGISTRATION=True
ENABLE_CTF_MODULE=True
ENABLE_TOURNAMENT_MODULE=True
MAINTENANCE_MODE=False
